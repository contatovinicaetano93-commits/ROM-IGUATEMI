# ROM CLUB IGUATEMI — variáveis de produção (projeto Vercel rom-club-iguatemi)
# Template completo: deploy/vercel-rom-club-iguatemi.env

ROM_PANEL=iguatemi
NEXT_PUBLIC_ROM_PANEL=iguatemi
ROM_SEED_PRESET=iguatemi

DATABASE_URL=

ROM_ADMIN_USER=admin
ROM_ADMIN_PASSWORD=
CRON_SECRET=

AVEC_API_URL=https://api.avec.beauty
AVEC_API_TOKEN=
AVEC_SYNC_MAX_PAGES=200
AVEC_WEBHOOK_SECRET=

# Sentry (Next.js) — DSN do projeto desta unidade na org imobi-hl
NEXT_PUBLIC_SENTRY_DSN=
# Opcional — upload de source maps no build (nunca commitar)
# SENTRY_AUTH_TOKEN=

# Resend — relatório de diretoria por e-mail (0011/0021)
RESEND_API_KEY=
DIRECTOR_REPORT_EMAIL=contato.vinicaetano93@gmail.com
# DIRECTOR_REPORT_FROM=ROM CLUB IGUATEMI <onboarding@resend.dev>

# IA — pode ser a mesma chave Anthropic nos dois projetos (opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=rom-iguatemi
WHATSAPP_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_STAFF_CHAT_IDS=

# Telegram — bot dedicado do financeiro (terceiro bot, separado do da equipe)
# Comandos: /financeiro (receita/despesas/margem) e /estoque (valor + alertas)
TELEGRAM_FINANCE_BOT_TOKEN=
TELEGRAM_FINANCE_WEBHOOK_SECRET=
TELEGRAM_FINANCE_CHAT_IDS=

# =============================================================================
# ROLES & ACCESS CONTROL
# =============================================================================
# Each role has specific dashboard access and is isolated from others.
# See src/middleware.ts for isolation logic.
#
# LOGIN — password PER unit (recommended to rotate monthly)
#
# Admin: Full access (all dashboards + admin panel)
# ROM_ADMIN_USER=admin
# ROM_ADMIN_PASSWORD=
# Access: /, /hoje, /dashboard, /admin, /contatos, /financeiro, /estoque, /onboarding
#
# Staff: Limited read-only access (no financials, no inventory)
ROM_STAFF_USER=FUNC-IGUATEMI
ROM_STAFF_PASSWORD=
# Access: /, /hoje, /onboarding only (no financeiro, estoque, admin, contatos)
#
# Finance (Financeiro): Financial dashboard + dual access to stock
ROM_FINANCE_USER=FINANCEIRO-IGUATEMI
ROM_FINANCE_PASSWORD=
# Access: /financeiro, /estoque (duplo), /onboarding (não: hoje, dashboard, contatos, admin)
# Note: Financeiro cuida de AMBOS financeiro e estoque
#
# Stock (Estoque): Inventory management (isolated from finance & other areas)
ROM_STOCK_USER=ESTOQUE-IGUATEMI
ROM_STOCK_PASSWORD=
# Access: /estoque, /onboarding only (não: financeiro, hoje, dashboard, contatos, admin)
# Note: Estoque é isolado — nunca vê financeiro ou operações gerais
#
ROM_ACCESS_TOKEN=

# Demo Avec sem token (só desenvolvimento)
AVEC_MOCK=
