# Neon (Postgres) — projeto dedicado ao ROM Iguatemi. Connection string com sslmode=require.
DATABASE_URL=

# IA — Claude (Anthropic): briefings, WhatsApp e Telegram
ANTHROPIC_API_KEY=
# Opcional — padrão: claude-sonnet-4-6. Para economizar: claude-3-5-haiku-latest
ANTHROPIC_MODEL=

# WhatsApp — Evolution API (instância própria da unidade Iguatemi)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
# Secret no header x-whatsapp-secret do webhook Evolution → /api/webhooks/whatsapp
WHATSAPP_WEBHOOK_SECRET=

# Telegram — bot dedicado ao ROM Iguatemi, criado via @BotFather
TELEGRAM_BOT_TOKEN=
# Secret que você define no setWebhook do Telegram (secret_token) — protege o endpoint
TELEGRAM_WEBHOOK_SECRET=
# Chat IDs da equipe Iguatemi (separados por vírgula) — recebem alerta de handoff do WhatsApp
TELEGRAM_STAFF_CHAT_IDS=

# Unidade ROM Iguatemi — sempre cite a unidade nos painéis e relatórios
SALON_UNIT_NAME=ROM Iguatemi
SALON_UNIT_SLUG=rom-iguatemi
SALON_BRAND=ROM Club
# Meta de faturamento diário (R$) — KPI inteligente "Meta do dia"
SALON_DAILY_GOAL=5000
# ID da unidade Iguatemi no painel Avec (quando souber)
AVEC_UNIT_ID=

# Avec — API de Relatórios (Postman: documenter.getpostman.com/view/12527228/2sA2xmUWJo)
# Base padrão: https://api.avec.beauty (só mude AVEC_API_URL se o suporte indicar outra)
AVEC_API_URL=https://api.avec.beauty
# Token gerado no painel Avec — vai direto no header Authorization (sem "Bearer")
AVEC_API_TOKEN=
# Webhook push (opcional): segredo no header x-avec-secret
AVEC_WEBHOOK_SECRET=
# Relatório 0011 (retorno por profissional) — override se o ID for outro nesta unidade
AVEC_REPORT_DIRECTOR_RETURN=

# Relatório de diretoria (0011/0021) — e-mail via Resend, terças 08:00 SP
RESEND_API_KEY=
DIRECTOR_REPORT_EMAIL=
# DIRECTOR_REPORT_FROM=ROM Iguatemi <onboarding@resend.dev>

# Vercel Cron — protege POST /api/avec/sync e /api/director-report (Bearer token)
# fast: */5 * * * * | full: 0 8 * * * | diretoria: 0 11 * * 2 (terça)
CRON_SECRET=

# Proteção do /admin — login com usuário e senha
ROM_ADMIN_USER=ADMIN-IGUATEMI
ROM_ADMIN_PASSWORD=
# Legado (opcional): se ROM_ADMIN_PASSWORD vazio, usa este valor como senha única
ROM_ACCESS_TOKEN=

# Modo demo Avec — sync com dados fictícios sem token real
AVEC_MOCK=
